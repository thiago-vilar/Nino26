    "    pc = ax.pcolormesh(lon, seg.index, seg.values, cmap='YlOrRd', vmin=0, vmax=15, shading='auto')\n",
    "    ax.axvline(190, color='k', ls='--', lw=0.6); ax.axvline(240, color='k', ls='--', lw=0.6)\n",
