    "dhw_lon = excesso.rolling(12, min_periods=12).sum()\n",
    "windows = [('2015-01-04','2016-06-26','2015/16'), ('2023-01-01','2024-06-30','2023/24'), ('2025-07-01', None, '2025/26 (atual)')]\n",
